PORT=3001
# Docker Compose: host is `postgres` on backend-network (see root docker-compose.yml).
# Local without Compose: map postgres to localhost only if you expose the port yourself.
DATABASE_URL=postgresql://ordering:ordering_dev@postgres:5432/ordering_dev
REDIS_URL=redis://redis:6379
STREAM_CONSUMER_NAME=ordering-1
STREAM_MAX_RETRIES=5
# RS256 public key (PEM) for JWT verification on future protected HTTP routes.
# Private key stays with the token issuer (e.g. future web panel). Use \n for line breaks.
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
